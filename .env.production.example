# Production profile. Copy to `.env.production` on the server.
VALUE_INVEST_ENV=production
APP_TITLE=Value Compass
PUBLIC_API_BASE_URL=https://cantabile.tplinkdns.com:3691
CORS_ALLOWED_ORIGINS=https://ducklove.github.io,https://cantabile.tplinkdns.com:3691
ENABLE_API_DOCS=0

# Production normally uses systemd timers for these pipelines.
WIKI_INGEST_INTERVAL_S=0
DART_REVIEW_INTERVAL_S=0
PORTFOLIO_INSIGHT_STARTUP_WARMUP=0

# Secrets should live in process env, `.kis.env`, or a local untracked secret
# manager file during migration. Do not commit real values.
GOOGLE_CLIENT_ID=
SESSION_SECRET=
OPENDART_API_KEY=
OPENROUTER_API_KEY=
INTERNAL_API_TOKEN=

# Optional AI tuning.
AI_MARKET_DAILY_MODEL=google/gemini-3.5-flash
MARKET_DAILY_CACHE_TTL_MINUTES=30
PORTFOLIO_AI_MAX_TOKENS=3200
