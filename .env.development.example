# Development profile.
VALUE_INVEST_ENV=development
APP_TITLE=Value Compass Dev
PUBLIC_API_BASE_URL=
ENABLE_API_DOCS=1

# Keep heavy background jobs off while iterating locally.
WIKI_INGEST_INTERVAL_S=0
DART_REVIEW_INTERVAL_S=0
PORTFOLIO_INSIGHT_STARTUP_WARMUP=0

AI_LIGHT_MODEL=qwen/qwen3.6-flash
AI_BALANCED_MODEL=google/gemini-3.5-flash
AI_PREMIUM_MODEL=openai/gpt-5.6-terra
PORTFOLIO_AI_MAX_TOKENS=8000
PORTFOLIO_AI_PREMIUM_REASONING_EFFORT=medium

# Looser local CORS for browser testing.
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8000,http://127.0.0.1:8000,http://localhost:8010,http://127.0.0.1:8010,http://localhost:5173,http://127.0.0.1:5173
