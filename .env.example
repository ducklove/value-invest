# Shared defaults for any environment. Copy to `.env` and keep secrets out of git.
APP_TITLE=Value Compass
PUBLIC_API_BASE_URL=
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8000,http://127.0.0.1:8000,http://localhost:8010,http://127.0.0.1:8010,https://ducklove.github.io,https://cantabile.tplinkdns.com:3691

# Background loops are disabled by default in app code unless explicitly set.
WIKI_INGEST_INTERVAL_S=0
DART_REVIEW_INTERVAL_S=0
PORTFOLIO_INSIGHT_STARTUP_WARMUP=0

# Portfolio condition alerts.
#   - 채널 자격증명은 '사용자별'로 등록한다(알림 모달에서 각자 봇 토큰/REST 키 입력).
#     아래 env 값들은 선택적 '공용 fallback'일 뿐, 없어도 사용자별 등록은 동작한다.
#   - NOTIFY_ALERT_INTERVAL_S > 0 이어야 주기 평가 루프가 돈다(예: 300=5분, 0=중지).
NOTIFY_ALERT_INTERVAL_S=0
NOTIFY_ALERT_INITIAL_DELAY_S=30

# (선택) 공용 텔레그램 봇 — 사용자가 봇 토큰을 직접 등록하지 않을 때의 fallback.
TELEGRAM_BOT_TOKEN=

# (선택) 공용 카카오 앱 — 사용자가 REST 키를 직접 등록하지 않을 때의 fallback.
# KAKAO_REDIRECT_URI 는 카카오 콘솔에 등록한 값과 정확히 일치해야 한다(미설정 시
# PUBLIC_API_BASE_URL 또는 요청 host 로 유추). 사용자별 앱이면 각자 콘솔에서
# 모달에 표시되는 Redirect URI 를 등록한다.
#   예) https://cantabile.tplinkdns.com:3691/api/notifications/kakao/callback
KAKAO_REST_API_KEY=
KAKAO_REDIRECT_URI=

# Korean bond yields (국고채 전 만기·통안채·KOFR) come from the Bank of Korea
# ECOS API. Get a free key at https://ecos.bok.or.kr and set it here (keep the
# real value OUT of git — in .env / real env). Without a key these indicators
# (KOFR/통안채1년/한국2·20·30년) simply return empty; the rest are unaffected.
ECOS_API_KEY=

# Request observability: any /api/* call slower than this (milliseconds) is
# recorded to system_events (source="http", kind="slow"); 5xx responses are
# always recorded (kind="error"). Lower it temporarily to profile a slow path.
SLOW_REQUEST_MS=1000

# AI model overrides.
AI_MARKET_DAILY_MODEL=google/gemini-3.5-flash
PORTFOLIO_AI_MAX_TOKENS=3200

# Local close-price API. Current-price realtime paths still use their own feeds.
CLOSE_PRICE_API_BASE_URL=http://192.168.68.84:8400
CLOSE_PRICE_API_TIMEOUT_SECONDS=2.5
CLOSE_PRICE_API_ENABLED=1

# KIS proxy compatibility. Prefer the local finance API for broad historical data,
# but keep this available for paths that still depend on KIS proxy behavior.
KIS_PROXY_BASE_URL=http://cantabile.tplinkdns.com:3288
KIS_PROXY_TIMEOUT_SECONDS=20
KIS_PROXY_RATE_PER_SEC=4
